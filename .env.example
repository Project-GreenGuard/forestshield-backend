# Copy to .env — never commit real secrets

FLASK_ENV=development
AWS_ENDPOINT_URL=http://dynamodb:8000
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_TABLE=WildfireSensorData

# Optional: NASA FIRMS area API (Ontario bbox). If empty, Lambda uses country CSV (no key).
NASA_MAP_KEY=

# Optional: full URL to Cloud Run predict endpoint (POST JSON).
# Example: https://your-service-xxxxx-uc.a.run.app/predict
# If empty, processing uses rule-based risk + local spread heuristic only.
CLOUD_RUN_PREDICT_URL=

CLOUD_RUN_TIMEOUT_SEC=8
